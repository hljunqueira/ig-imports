# IG Imports - API Environment Variables
# Copy this file to .env and fill in your values

# Backend Port
BACKEND_PORT=3001

# Database Connection (connects to ig-imports-database)
DB_HOST=76.13.171.93
DB_PORT=5432
DB_NAME=igimports_db
DB_USER=postgres
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

# JWT Configuration (must match database JWT_SECRET)
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# CORS (allow frontend domains)
CORS_ORIGIN=http://localhost:5173,https://igimports.com.br
